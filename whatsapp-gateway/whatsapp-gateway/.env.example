# Porta do gateway
PORT=3001

# Chave secreta usada para assinar webhooks com HMAC-SHA256
GATEWAY_SECRET=troque-por-uma-chave-secreta-forte

# URL do seu backend Fastify (para enviar webhooks)
CRM_WEBHOOK_URL=http://localhost:3333/webhooks/whatsapp

# Pasta onde as sessões do WhatsApp ficam salvas
SESSIONS_DIR=./sessions

# Nível de log: trace | debug | info | warn | error
LOG_LEVEL=info
