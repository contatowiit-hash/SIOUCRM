{
  "name": "syntra-food",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build && npm run preview",
    "dev:vite": "vite --host 127.0.0.1 --configLoader native",
    "dev:api": "tsx watch server/src/index.ts",
    "start:api": "tsx server/src/index.ts",
    "serve:site": "node server/local-static.cjs",
    "start:local": "npm run build && concurrently -n API,SITE -c cyan,blue \"npm:dev:api\" \"npm:serve:site\"",
    "dev:full": "npm run start:local",
    "build": "tsc -b && vite build --configLoader native",
    "build:api": "tsc -p server/tsconfig.json",
    "db:migrate": "tsx server/src/scripts/migrate.ts",
    "test:menu-pdf": "node --import tsx --test server/src/__tests__/menu-pdf.test.ts",
    "test:import-orders": "node --import tsx --test server/src/__tests__/import-orders.test.ts",
    "test:metered": "node --import tsx --test server/src/__tests__/metered-billing.test.ts",
    "test:security": "node --import tsx --test server/src/__tests__/security.test.ts",
    "test:integrations": "node --import tsx --test server/src/__tests__/integrations.test.ts server/src/__tests__/remaining-payments.test.ts",
    "test": "npm run test:menu-pdf && npm run test:import-orders && npm run test:metered && npm run test:security && npm run test:integrations",
    "preview": "vite preview --host 127.0.0.1 --configLoader native",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@hookform/resolvers": "^3.9.1",
    "@napi-rs/canvas": "^0.1.80",
    "@react-oauth/google": "^0.13.5",
    "@tanstack/react-query": "^5.62.8",
    "@types/nodemailer": "^8.0.1",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "disposable-email-domains": "^1.0.62",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "fastify": "^5.8.5",
    "google-auth-library": "^10.9.0",
    "jose": "^6.2.3",
    "lucide-react": "^0.468.0",
    "nodemailer": "^9.0.1",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^7.1.1",
    "recharts": "^3.8.1",
    "stripe": "^22.2.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.3",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^6.0.7"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
